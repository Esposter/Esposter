{
  "name": "@esposter/shared-node",
  "version": "2.31.1",
  "private": true,
  "description": "Node-only shared tooling (benchmark reporting, dev scripts) reused across packages.",
  "keywords": [
    "benchmark",
    "codspeed",
    "dev-scripts",
    "monorepo",
    "node",
    "reporting",
    "shared",
    "tooling",
    "typescript",
    "vitest"
  ],
  "homepage": "https://github.com/Esposter/Esposter/blob/main/packages/shared-node#readme",
  "bugs": {
    "url": "https://github.com/Esposter/Esposter/issues"
  },
  "license": "Apache-2.0",
  "author": "Jimmy Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Esposter/Esposter.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./reporter": {
      "types": "./dist/reporter.d.ts",
      "default": "./dist/reporter.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "default": "./dist/runner.js"
    }
  },
  "scripts": {
    "build": "pnpm export:gen && rolldown --config rolldown.config.ts",
    "export:gen": "ctix build --config ../configuration/.ctirc-ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "@esposter/shared": "workspace:*"
  },
  "devDependencies": {
    "@esposter/configuration": "workspace:*",
    "@types/node": "catalog:",
    "ctix": "catalog:",
    "rolldown": "catalog:"
  },
  "peerDependencies": {
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
