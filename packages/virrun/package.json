{
  "name": "virrun",
  "version": "2.31.1",
  "description": "An ephemeral, in-memory virtual runner that runs a repo's real toolchain fast and isolated.",
  "keywords": [
    "ci",
    "cli",
    "in-memory",
    "isolated",
    "monorepo",
    "runner",
    "sandbox",
    "testing",
    "toolchain",
    "typescript",
    "vfs",
    "virtual"
  ],
  "homepage": "https://github.com/Esposter/Esposter/blob/main/packages/virrun#readme",
  "bugs": {
    "url": "https://github.com/Esposter/Esposter/issues"
  },
  "license": "Apache-2.0",
  "author": "Jimmy Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Esposter/Esposter.git"
  },
  "bin": {
    "virrun": "dist/cli.js"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bench": "vitest bench --run",
    "build": "pnpm export:gen && rolldown --config rolldown.config.ts",
    "export:gen": "ctix build --config ../configuration/.ctirc-ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest",
    "typecheck": "tsgo"
  },
  "devDependencies": {
    "@codspeed/vitest-plugin": "catalog:",
    "@esposter/configuration": "workspace:*",
    "@esposter/shared": "workspace:*",
    "@esposter/shared-node": "workspace:*",
    "@platformatic/vfs": "catalog:",
    "@types/node": "catalog:",
    "citty": "catalog:",
    "ctix": "catalog:",
    "dayjs": "catalog:",
    "empathic": "catalog:",
    "fast-check": "catalog:",
    "rolldown": "catalog:",
    "vitest": "catalog:"
  }
}
