{
  "name": "@esposter/configuration",
  "version": "2.30.0",
  "private": true,
  "description": "A library that contains shared configuration.",
  "keywords": [
    "ctix",
    "eslint",
    "rolldown",
    "typescript",
    "vite"
  ],
  "homepage": "https://github.com/Esposter/Esposter/blob/main/packages/configuration#readme",
  "bugs": {
    "url": "https://github.com/Esposter/Esposter/issues"
  },
  "license": "Apache-2.0",
  "author": "Jimmy Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Esposter/Esposter.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm export:gen && rolldown --config rolldown.config.ts",
    "export:gen": "ctix build --config .ctirc-ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint && eslint .",
    "lint:fix": "oxlint --fix && eslint --fix .",
    "test": "vitest",
    "typecheck": "tsgo"
  },
  "devDependencies": {
    "@dxup/nuxt": "catalog:",
    "@dxup/unimport": "catalog:",
    "@eslint/core": "catalog:",
    "@eslint/json": "catalog:",
    "@ninoseki/eslint-plugin-neverthrow": "catalog:",
    "@rolldown/plugin-node-polyfills": "catalog:",
    "@types/node": "catalog:",
    "@unocss/eslint-config": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/eslint-plugin": "catalog:",
    "@vue/language-core": "catalog:",
    "ctix": "catalog:",
    "eslint-plugin-depend": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-pinia": "catalog:",
    "rolldown": "catalog:",
    "rolldown-plugin-dts": "catalog:",
    "type-fest": "catalog:",
    "typescript-eslint": "catalog:",
    "unplugin-auto-import": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vite-plugin-mkcert": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@codspeed/vitest-plugin": "catalog:"
  },
  "peerDependenciesMeta": {
    "@codspeed/vitest-plugin": {
      "optional": true
    }
  }
}
