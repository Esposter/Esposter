{
  "name": "@esposter/db-mock",
  "version": "2.31.1",
  "private": true,
  "description": "A library of database mock utilities for testing, available in server environment only.",
  "keywords": [
    "database",
    "drizzle",
    "drizzle-orm",
    "in-memory",
    "mock",
    "orm",
    "pg",
    "pglite",
    "postgres",
    "postgresql",
    "test",
    "testing",
    "ts",
    "typescript",
    "vitest"
  ],
  "homepage": "https://github.com/Esposter/Esposter/blob/main/packages/db-mock#readme",
  "bugs": {
    "url": "https://github.com/Esposter/Esposter/issues"
  },
  "license": "Apache-2.0",
  "author": "Jimmy Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Esposter/Esposter.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm export:gen && rolldown --config rolldown.config.ts && tsx scripts/copySnapshot.ts",
    "export:gen": "ctix build --config ../configuration/.ctirc-ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "snapshot:gen": "tsx scripts/generateSnapshot.ts",
    "test": "vitest",
    "typecheck": "tsgo"
  },
  "devDependencies": {
    "@esposter/configuration": "workspace:*",
    "@types/node": "catalog:",
    "ctix": "catalog:",
    "drizzle-kit": "catalog:",
    "rolldown": "catalog:",
    "tsx": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@electric-sql/pglite": "catalog:",
    "@esposter/db-schema": "workspace:*",
    "drizzle-orm": "catalog:"
  }
}
