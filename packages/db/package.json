{
  "name": "@esposter/db",
  "version": "2.30.0",
  "private": true,
  "description": "A library of database utilities that is available in server environment only.",
  "keywords": [
    "database",
    "drizzle",
    "orm",
    "pg",
    "postgres",
    "postgresql",
    "schema",
    "sql",
    "ts",
    "typescript"
  ],
  "homepage": "https://github.com/Esposter/Esposter/blob/main/packages/db#readme",
  "bugs": {
    "url": "https://github.com/Esposter/Esposter/issues"
  },
  "license": "Apache-2.0",
  "author": "Jimmy Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Esposter/Esposter.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm export:gen && rolldown --config rolldown.config.ts",
    "export:gen": "ctix build --config ../configuration/.ctirc-ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "@esposter/shared": "workspace:*",
    "dayjs": "catalog:",
    "link-preview-js": "catalog:",
    "linkifyjs": "catalog:",
    "mime-types": "catalog:",
    "node-html-parser": "catalog:"
  },
  "devDependencies": {
    "@esposter/configuration": "workspace:*",
    "@esposter/db-mock": "workspace:*",
    "@types/mime-types": "catalog:",
    "ctix": "catalog:",
    "rolldown": "catalog:",
    "type-fest": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@azure/core-client": "catalog:",
    "@azure/data-tables": "catalog:",
    "@azure/search-documents": "catalog:",
    "@azure/storage-blob": "catalog:",
    "@azure/storage-queue": "catalog:",
    "@azure/web-pubsub": "catalog:",
    "@esposter/db-schema": "workspace:*",
    "drizzle-orm": "catalog:"
  }
}
