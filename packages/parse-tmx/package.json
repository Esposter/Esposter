{
  "name": "parse-tmx",
  "version": "2.31.1",
  "description": "A parser for tmx.",
  "keywords": [
    "game-development",
    "gamedev",
    "map",
    "parser",
    "phaser",
    "tiled",
    "tiled-map-editor",
    "tilemap",
    "tmx",
    "typescript",
    "xml"
  ],
  "homepage": "https://github.com/Esposter/Esposter/blob/main/packages/parse-tmx#readme",
  "bugs": {
    "url": "https://github.com/Esposter/Esposter/issues"
  },
  "license": "Apache-2.0",
  "author": "Jimmy Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Esposter/Esposter.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm export:gen && rolldown --config rolldown.config.ts",
    "export:gen": "ctix build --config ../configuration/.ctirc-ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "@esposter/shared": "workspace:*",
    "@esposter/xml2js": "workspace:*",
    "data-urls": "catalog:",
    "dayjs": "catalog:"
  },
  "devDependencies": {
    "@esposter/configuration": "workspace:*",
    "@types/data-urls": "catalog:",
    "@types/xml2js": "catalog:",
    "ctix": "catalog:",
    "rolldown": "catalog:",
    "type-fest": "catalog:",
    "vitest": "catalog:"
  }
}
