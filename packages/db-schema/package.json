{
  "name": "@esposter/db-schema",
  "version": "2.31.1",
  "private": true,
  "description": "A library of database schemas and utilities using Drizzle ORM (PostgreSQL) that is available in both browser and server environments.",
  "keywords": [
    "azure",
    "database",
    "drizzle",
    "drizzle-kit",
    "drizzle-orm",
    "migrations",
    "orm",
    "pg",
    "postgres",
    "postgresql",
    "schema",
    "sql",
    "ts",
    "typescript",
    "zod"
  ],
  "homepage": "https://github.com/Esposter/Esposter/blob/main/packages/db-schema#readme",
  "bugs": {
    "url": "https://github.com/Esposter/Esposter/issues"
  },
  "license": "Apache-2.0",
  "author": "Jimmy Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Esposter/Esposter.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm export:gen && rolldown --config rolldown.config.ts",
    "db:gen": "pnpm db:run generate",
    "db:pull": "pnpm db:run pull",
    "db:run": "tsx node_modules/drizzle-kit/bin.cjs",
    "db:studio": "pnpm db:run studio",
    "db:up": "pnpm db:run up",
    "export:gen": "ctix build --config ../configuration/.ctirc-ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest",
    "typecheck": "tsgo"
  },
  "devDependencies": {
    "@esposter/configuration": "workspace:*",
    "@trpc/server": "catalog:",
    "ctix": "catalog:",
    "drizzle-kit": "catalog:",
    "rolldown": "catalog:",
    "type-fest": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@azure/data-tables": "catalog:",
    "@azure/storage-blob": "catalog:",
    "@esposter/shared": "workspace:*",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  }
}
