{
  "name": "esposter",
  "description": "A nice and casual place for posting random things.",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "homepage": "https://github.com/Esposter/Esposter#readme",
  "license": "Apache-2.0",
  "author": "Jimmy Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Esposter/Esposter.git"
  },
  "bugs": {
    "url": "https://github.com/Esposter/Esposter/issues"
  },
  "scripts": {
    "build": "bun build:packages && bun build:docs && bun build:app",
    "build:app": "lerna run build --scope=@esposter/app",
    "build:docs": "typedoc",
    "build:packages": "lerna run build --ignore @esposter/app",
    "start": "lerna run start --scope=@esposter/app",
    "test": "lerna run test",
    "typecheck": "lerna run typecheck",
    "typecheck:packages": "bun typecheck --ignore @esposter/app",
    "lint": "lerna run lint",
    "lint:fix": "lerna run lint:fix",
    "lint:fix:packages": "bun lint:fix --ignore @esposter/app",
    "release": "bun build:packages && bun lint:fix:packages && bun typecheck:packages && lerna publish --yes",
    "refresh:lockfile": "bun cross-os refresh:lockfile",
    "cross-os": "bun packages/app/scripts/cross-os.ts",
    "pwsh": "pwsh -ExecutionPolicy Unrestricted"
  },
  "cross-os": {
    "refresh:lockfile": {
      "win32": "bun pwsh scripts/refreshLockfile.ps1",
      "linux": "./scripts/refreshLockfile.sh"
    }
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@lerna-lite/cli": "^3.12.1",
    "@lerna-lite/publish": "^3.12.1",
    "@lerna-lite/run": "^3.12.1",
    "ctix": "^2.7.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.20.1",
    "rollup": "^4.34.8",
    "type-fest": "^4.35.0",
    "typedoc": "^0.27.7",
    "typescript": "^5.7.3",
    "vite": "^6.1.1",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vue-tsc": "^2.2.2"
  },
  "engines": {
    "bun": "^1.2.2"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "core-js",
    "esbuild",
    "vue-demi"
  ]
}
