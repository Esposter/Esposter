{
  "name": "esposter",
  "version": "1.0.0",
  "description": "A nice and casual place for posting random things.",
  "keywords": [
    "azure",
    "chat",
    "drizzle-orm",
    "monorepo",
    "nuxt",
    "phaser",
    "pinia",
    "pnpm",
    "postgresql",
    "pwa",
    "realtime",
    "serverless",
    "social-platform",
    "trpc",
    "typescript",
    "unocss",
    "vite",
    "vue",
    "vuetify",
    "zod"
  ],
  "homepage": "https://github.com/Esposter/Esposter#readme",
  "bugs": {
    "url": "https://github.com/Esposter/Esposter/issues"
  },
  "license": "Apache-2.0",
  "author": "Jimmy Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Esposter/Esposter.git"
  },
  "type": "module",
  "scripts": {
    "bench": "vitest bench --run --project scripts && pnpm -r --if-present run bench",
    "build": "pnpm build:packages && pnpm build:docs && pnpm build:app",
    "build:app": "pnpm --filter @esposter/app run build",
    "build:docker": "pnpm crossOS copyfiles .gitignore .dockerignore && docker compose -f docker-compose.dev.yaml build",
    "build:docs": "typedoc",
    "build:packages": "pnpm -r --filter \"!@esposter/app\" run build",
    "coverage": "vitest run --coverage",
    "crossOS": "node scripts/crossOS.ts",
    "depcruise:graph": "depcruise packages/*/src/index.ts --include-only \"^packages\" --collapse 2 --output-type dot | graphviz -Tsvg > dependency-graph.svg",
    "dev:docker": "docker compose -f docker-compose.dev.yaml up",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint && eslint . && pnpm -r --parallel --aggregate-output run lint",
    "lint:fix": "oxlint --fix && eslint --fix . && pnpm -r --parallel --aggregate-output run lint:fix",
    "lint:fix:packages": "oxlint --fix --ignore-pattern \"packages/app/**\" packages && pnpm -r --filter \"!@esposter/app\" --parallel --aggregate-output run lint:fix",
    "lint:packages": "oxlint --ignore-pattern \"packages/app/**\" packages && pnpm -r --filter \"!@esposter/app\" --parallel --aggregate-output run lint",
    "outdated:dependencies": "tsx scripts/checkDependencies/index.ts",
    "prepare": "git config core.hooksPath .githooks || true",
    "pwsh": "pwsh -ExecutionPolicy Unrestricted",
    "refresh:lockfile": "pnpm crossOS refresh:lockfile",
    "release": "pnpm build:packages && pnpm lint:fix:packages && pnpm format && pnpm typecheck:packages && lerna publish --yes",
    "start": "pnpm --filter @esposter/app run start",
    "test": "vitest run",
    "test:packages": "vitest run --project \"!@esposter/app\"",
    "typecheck": "tsgo && pnpm -r --parallel --aggregate-output run typecheck",
    "typecheck:packages": "pnpm -r --filter \"!@esposter/app\" --parallel --aggregate-output run typecheck",
    "watch:packages": "pnpm -r --filter \"!@esposter/app\" --parallel --stream --if-present run watch"
  },
  "devDependencies": {
    "@esposter/configuration": "workspace:*",
    "@esposter/shared": "workspace:*",
    "@esposter/shared-node": "workspace:*",
    "@lerna-lite/cli": "catalog:",
    "@lerna-lite/publish": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "dependency-cruiser": "catalog:",
    "dotenv": "catalog:",
    "eslint": "catalog:",
    "graphviz-cli": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsx": "catalog:",
    "typedoc": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^26.3.1"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "crossOS": {
    "copyfiles": {
      "darwin": "cp -f",
      "linux": "cp -f",
      "win32": "pnpm pwsh -Command Copy-Item -Force"
    },
    "refresh:lockfile": {
      "darwin": "sh ./scripts/refreshLockfile.sh",
      "linux": "./scripts/refreshLockfile.sh",
      "win32": "pnpm pwsh scripts/refreshLockfile.ps1"
    }
  }
}
