{
  "name": "esposter",
  "version": "1.0.0",
  "description": "A nice and casual place for posting random things.",
  "homepage": "https://github.com/Esposter/Esposter#readme",
  "bugs": {
    "url": "https://github.com/Esposter/Esposter/issues"
  },
  "license": "Apache-2.0",
  "author": "Jimmy Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Esposter/Esposter.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm build:packages && pnpm build:docs && pnpm build:app",
    "build:app": "NODE_OPTIONS=--max-old-space-size=8192 lerna run build --scope=@esposter/app",
    "build:docker": "pnpm crossOS copyfiles .gitignore .dockerignore && docker compose -f docker-compose.dev.yaml build",
    "build:docs": "typedoc",
    "build:packages": "lerna run build --ignore @esposter/app",
    "coverage": "lerna run coverage",
    "crossOS": "node scripts/crossOS.ts",
    "dev:docker": "docker compose -f docker-compose.dev.yaml up",
    "format": "oxfmt",
    "prepare": "git config core.hooksPath .githooks || true",
    "format:check": "oxfmt --check",
    "lint": "oxlint --disable-nested-config && eslint . && lerna run lint",
    "lint:fix": "oxlint --disable-nested-config --fix && eslint --fix . && lerna run lint:fix",
    "lint:fix:packages": "pnpm lint:fix --ignore @esposter/app",
    "pwsh": "pwsh -ExecutionPolicy Unrestricted",
    "refresh:lockfile": "pnpm crossOS refresh:lockfile",
    "release": "pnpm build:packages && pnpm lint:fix:packages && pnpm format && pnpm typecheck:packages && lerna publish --yes",
    "start": "lerna run start --scope=@esposter/app",
    "test": "lerna run test",
    "typecheck": "tsgo && lerna run typecheck",
    "typecheck:packages": "pnpm typecheck --ignore @esposter/app",
    "watch:packages": "lerna watch --ignore @esposter/app -- pnpm build:packages"
  },
  "devDependencies": {
    "@esposter/configuration": "workspace:*",
    "@lerna-lite/cli": "catalog:",
    "@lerna-lite/publish": "catalog:",
    "@lerna-lite/run": "catalog:",
    "@lerna-lite/watch": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "dotenv": "catalog:",
    "eslint": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsx": "catalog:",
    "typedoc": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "^24.15.0"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "crossOS": {
    "copyfiles": {
      "darwin": "cp -f",
      "linux": "cp -f",
      "win32": "pnpm pwsh -Command Copy-Item -Force"
    },
    "refresh:lockfile": {
      "darwin": "sh ./scripts/refreshLockfile.sh",
      "linux": "./scripts/refreshLockfile.sh",
      "win32": "pnpm pwsh scripts/refreshLockfile.ps1"
    }
  }
}
