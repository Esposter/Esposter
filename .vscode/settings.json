{
  "[javascript][typescript][vue]": {
    "editor.codeActionsOnSave": ["source.organizeImports", "source.fixAll.oxc", "source.fixAll.eslint"]
  },
  "[xml]": {
    "editor.formatOnSave": false
  },
  "azureFunctions.deploySubpath": "packages\\azure-functions",
  "azureFunctions.postDeployTask": "pnpm i (functions)",
  "azureFunctions.preDeployTask": "pnpm prune (functions)",
  "azureFunctions.projectLanguage": "TypeScript",
  "azureFunctions.projectRuntime": "~4",
  "debug.internalConsoleOptions": "neverOpen",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.gotoLocation.multipleDefinitions": "goto",
  "files.associations": {
    ".env": "env",
    ".env.example": "env",
    ".tsx": "xml"
  },
  "javascript.updateImportsOnFileMove.enabled": "always",
  "oxc.enable": true,
  // oxc.path.node lives in the gitignored Esposter.code-workspace (machine-specific fnm path).
  // Reason: oxc cannot expand ${env:}/~ yet — https://github.com/oxc-project/oxc-vscode/issues/249
  "search.followSymlinks": false,
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.tsserver.maxTsServerMemory": 16384,
  "typescript.tsserver.nodePath": "${env:FNM_DIR}/aliases/default/node.exe",
  "typescript.updateImportsOnFileMove.enabled": "always"
}
